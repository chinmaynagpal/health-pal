# Public app URL — used for metadata, canonical links, and CORS allow-list.
# In local dev leave it as http://localhost:3000; in production set to https://healthpal.com.
NEXT_PUBLIC_APP_URL=https://healthpal.com

MONGODB_URI=mongodb://localhost:27017/healthpal
JWT_SECRET=replace_with_long_random_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Google Gemini
GEMINI_API_KEY=

# USDA FoodData Central (https://fdc.nal.usda.gov/api-key-signup.html)
USDA_API_KEY=

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
